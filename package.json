{
  "name": "@sebastiandotdev/vue3-datatable",
  "type": "module",
  "version": "0.3.3",
  "private": false,
  "packageManager": "pnpm@11.2.1",
  "description": "Vue3 Datatable - fully customizable & easy to use datatable library",
  "author": {
    "name": "Sebastián García",
    "email": "joangarcia.dev@gmail.com",
    "url": "https://github.com/joangarciaa-dev"
  },
  "contributors": [
    {
      "name": "Bhavesh Patel",
      "email": "bhavesh.patel200@gmail.com",
      "url": "https://github.com/bhaveshpatel200"
    }
  ],
  "license": "MIT",
  "homepage": "https://github.com/joangarciaa-dev/vue3-datatable#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joangarciaa-dev/vue3-datatable.git"
  },
  "bugs": {
    "url": "https://github.com/joangarciaa-dev/vue3-datatable/issues"
  },
  "keywords": [
    "vue3",
    "vue",
    "vuejs",
    "component",
    "datatable",
    "vue3 datatable",
    "vue datatable",
    "vue3-datatable",
    "vue grid",
    "vue3 grid",
    "vue table",
    "vue3 table",
    "datagrid",
    "data-grid",
    "data-table",
    "table",
    "grid",
    "filter",
    "sorting",
    "pagination"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue3-datatable.js",
      "require": "./dist/vue3-datatable.umd.js"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "main": "./dist/vue3-datatable.umd.js",
  "module": "./dist/vue3-datatable.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --emitDeclarationOnly && npm run tailwind:build",
    "preview": "vite preview",
    "lint": "eslint .",
    "fmt": "eslint . --fix",
    "tailwind": "npx tailwindcss -i ./src/assets/css/tailwind.css -o ./dist/style.css --watch",
    "tailwind:build": "npx tailwindcss -i ./src/assets/css/tailwind.css -o ./dist/style.css --minify"
  },
  "dependencies": {
    "vue": "^3.5.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^22.5.4",
    "@vitejs/plugin-vue": "^5.1.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "jiti": "^2.7.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.4",
    "vite-plugin-dts": "^4.2.1",
    "vue-tsc": "^2.1.6"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
